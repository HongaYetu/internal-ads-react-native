{
  "name": "@hongayetu/internal-ads-react-native",
  "version": "0.8.0",
  "description": "SDK React Native para servir e tracking de anúncios da plataforma HongaYetu (consumidor da API v2).",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/HongaYetu/internal-ads-react-native.git"
  },
  "license": "UNLICENSED",
  "private": false,
  "peerDependencies": {
    "expo-video": ">=2.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-mmkv": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "expo-video": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "react-native-mmkv": "^4.1.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "hongayetu",
    "ads",
    "react-native",
    "advertising",
    "internal"
  ]
}
